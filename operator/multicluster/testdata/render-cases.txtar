  replicas: 3
-- custom-config --
apiVersion: cluster.redpanda.com/v1alpha2
kind: StretchCluster
metadata:
  name: cluster
  namespace: default
spec:
  config:
    cluster:
      log_segment_size: 134217728
      group_topic_partitions: 16
      default_topic_replications: 3
    tunable:
      kafka_batch_max_bytes: 1048576
    node:
      developer_mode: true
---
apiVersion: cluster.redpanda.com/v1alpha2
kind: NodePool
metadata:
  name: pool-a
  namespace: default
spec:
  clusterRef:
    group: cluster.redpanda.com/v1alpha2
    kind: StretchCluster
    name: cluster
  replicas: 3
-- init-containers --
apiVersion: cluster.redpanda.com/v1alpha2
kind: StretchCluster
metadata:
  name: cluster
  namespace: default
---
apiVersion: cluster.redpanda.com/v1alpha2
kind: NodePool
metadata:
  name: pool-a
  namespace: default
spec:
  clusterRef:
    group: cluster.redpanda.com/v1alpha2
    kind: StretchCluster
    name: cluster
  replicas: 3
  initContainers:
    fsValidator:
      enabled: true
      expectedFS: ext4
    setDataDirOwnership:
      enabled: true
-- custom-image --
apiVersion: cluster.redpanda.com/v1alpha2
kind: StretchCluster
metadata:
  name: cluster
  namespace: default
spec:
  image:
    repository: custom-registry.example.com/redpanda
    tag: v24.3.1
  imagePullSecrets:
    - name: regcred
---
apiVersion: cluster.redpanda.com/v1alpha2
kind: NodePool
metadata:
  name: pool-a
  namespace: default
spec:
  clusterRef:
    group: cluster.redpanda.com/v1alpha2
    kind: StretchCluster
    name: cluster
  replicas: 3
  image:
    repository: custom-registry.example.com/redpanda
    tag: v24.3.1
  sidecarImage:
    repository: custom-registry.example.com/operator
    tag: v24.3.1
-- custom-cluster-domain --
apiVersion: cluster.redpanda.com/v1alpha2
kind: StretchCluster
metadata:
  name: cluster
  namespace: default
spec:
  clusterDomain: custom.local
