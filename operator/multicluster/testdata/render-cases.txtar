-- full-featured --
apiVersion: cluster.redpanda.com/v1alpha2
kind: StretchCluster
metadata:
  name: cluster
  namespace: default
spec:
  commonLabels:
    team: data-platform
  rackAwareness:
    enabled: true
  auth:
    sasl:
      enabled: true
      mechanism: SCRAM-SHA-512
      secretRef: users-secret
  tls:
    enabled: true
    certs:
      default:
        caEnabled: true
  external:
    enabled: true
    type: LoadBalancer
    domain: prod.example.com
    service:
      enabled: true
  listeners:
    kafka:
      port: 9093
      tls:
        cert: default
      external:
        default:
          enabled: true
          port: 30092
          tls:
            cert: default
    admin:
      port: 9644
      tls:
        cert: default
      external:
        default:
          enabled: true
          port: 30644
          tls:
            cert: default
    http:
      port: 8082
      tls:
        cert: default
      external:
        default:
          enabled: true
          port: 30082
          tls:
            cert: default
    schemaRegistry:
      port: 8081
      tls:
        cert: default
      external:
        default:
          enabled: true
          port: 30081
          tls:
            cert: default
    rpc:
      port: 33145
      tls:
        cert: default
  monitoring:
    enabled: true
  auditLogging:
    enabled: true
  storage:
    persistentVolume:
      enabled: true
      size: 100Gi
      storageClass: fast-ssd
    tiered:
      mountType: persistentVolume
      persistentVolume:
        storageClass: gp3
      config:
        cloud_storage_enabled: true
        cloud_storage_region: us-east-1
        cloud_storage_bucket: prod-tiered
        cloud_storage_credentials_source: aws_instance_metadata
        cloud_storage_cache_size: 20Gi
  resources:
    cpu:
      cores: "8"
    memory:
      container:
        max: 16Gi
      redpanda:
        memory: 12Gi
  enterprise:
    licenseSecretRef:
      name: redpanda-license
      key: license.key
  config:
    cluster:
      default_topic_replications: 3
      log_segment_size: 134217728
---
apiVersion: cluster.redpanda.com/v1alpha2
kind: NodePool
metadata:
  name: pool-hot
  namespace: default
spec:
  clusterRef:
    group: cluster.redpanda.com/v1alpha2
    kind: StretchCluster
    name: cluster
  replicas: 3
  additionalRedpandaCmdFlags:
    - "--idle-poll-time-us=0"
  additionalSelectorLabels:
    tier: hot
  initContainers:
    fsValidator:
      enabled: true
---
apiVersion: cluster.redpanda.com/v1alpha2
kind: NodePool
metadata:
  name: pool-cold
  namespace: default
spec:
  clusterRef:
    group: cluster.redpanda.com/v1alpha2
    kind: StretchCluster
    name: cluster
  replicas: 2
  additionalSelectorLabels:
    tier: cold
