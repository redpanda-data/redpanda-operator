        - address: storage-hostpath-pool-a-1.storage-hostpath.storage-hostpath.svc.cluster.local.
          port: 9093
        - address: storage-hostpath-pool-a-2.storage-hostpath.storage-hostpath.svc.cluster.local.
          port: 9093
