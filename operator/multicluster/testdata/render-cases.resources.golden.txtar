- apiVersion: rbac.authorization.k8s.io/v1
  kind: RoleBinding
  metadata:
    labels:
      app.kubernetes.io/component: redpanda
      app.kubernetes.io/instance: audit-logging-test
      app.kubernetes.io/managed-by: redpanda-operator
