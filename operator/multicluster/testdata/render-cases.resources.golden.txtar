  data:
    profile: |-
      admin_api:
        addresses: []
        tls:
          ca_file: ca.crt
      kafka_api:
        brokers: []
        tls:
          ca_file: ca.crt
      name: default
      schema_registry:
        addresses: []
        tls:
          ca_file: ca.crt
