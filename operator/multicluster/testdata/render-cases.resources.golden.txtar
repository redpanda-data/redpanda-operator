        overprovisioned: false
        schema_registry:
          addresses:
          - tls-mtls-test-pool-a-0.tls-mtls-test.tls-mtls.svc.cluster.local.:8081
          - tls-mtls-test-pool-a-1.tls-mtls-test.tls-mtls.svc.cluster.local.:8081
          - tls-mtls-test-pool-a-2.tls-mtls-test.tls-mtls.svc.cluster.local.:8081
