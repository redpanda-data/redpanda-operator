          key_file: /etc/tls/certs/external/tls.key
          name: default
          require_client_auth: false
          truststore_file: /etc/tls/certs/external/ca.crt
      schema_registry_client:
        broker_tls:
          enabled: true
          require_client_auth: false
          truststore_file: /etc/tls/certs/default/ca.crt
        brokers:
        - address: tiered-storage-emptydir-test-pool-a-0.tiered-storage-emptydir-test.tiered-storage-emptydir.svc.cluster.local.
          port: 9093
        - address: tiered-storage-emptydir-test-pool-a-1.tiered-storage-emptydir-test.tiered-storage-emptydir.svc.cluster.local.
          port: 9093
        - address: tiered-storage-emptydir-test-pool-a-2.tiered-storage-emptydir-test.tiered-storage-emptydir.svc.cluster.local.
          port: 9093
