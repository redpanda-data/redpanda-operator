          enabled: true
          key_file: /etc/tls/certs/default-client/tls.key
          require_client_auth: true
          truststore_file: /etc/tls/certs/default/ca.crt
        brokers:
        - address: tls-mtls-test-pool-a-0.tls-mtls-test.tls-mtls.svc.cluster.local.
