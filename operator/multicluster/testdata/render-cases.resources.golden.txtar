      pandaproxy_client:
        broker_tls:
          enabled: true
          require_client_auth: false
          truststore_file: /etc/tls/certs/default/ca.crt
        brokers:
        - address: storage-pv-custom-test-pool-a-0.storage-pv-custom-test.storage-pv-custom.svc.cluster.local.
