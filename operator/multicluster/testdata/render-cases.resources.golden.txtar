          require_client_auth: false
          truststore_file: /etc/tls/certs/external/ca.crt
      pandaproxy_client:
        broker_tls:
          enabled: true
          require_client_auth: false
          truststore_file: /etc/tls/certs/default/ca.crt
        brokers:
        - address: custom-resources-test-pool-a-0.custom-resources-test.custom-resources.svc.cluster.local.
          port: 9093
        - address: custom-resources-test-pool-a-1.custom-resources-test.custom-resources.svc.cluster.local.
