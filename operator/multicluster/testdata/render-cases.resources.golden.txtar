            key_file: /etc/tls/certs/default-client/tls.key
        enable_memory_locking: false
        kafka_api:
          brokers:
          - tls-mtls-test-pool-a-0.tls-mtls-test.tls-mtls.svc.cluster.local.:9093
          - tls-mtls-test-pool-a-1.tls-mtls-test.tls-mtls.svc.cluster.local.:9093
          - tls-mtls-test-pool-a-2.tls-mtls-test.tls-mtls.svc.cluster.local.:9093
