          - custom-resources-explicit-test-pool-a-1.custom-resources-explicit-test.custom-resources-explicit.svc.cluster.local.:8081
          - custom-resources-explicit-test-pool-a-2.custom-resources-explicit-test.custom-resources-explicit.svc.cluster.local.:8081
          tls:
            ca_file: /etc/tls/certs/default/ca.crt
        tune_aio_events: true
      schema_registry:
        schema_registry_api:
        - address: 0.0.0.0
          name: internal
          port: 8081
        - address: 0.0.0.0
          name: default
          port: 8084
