        - cert_file: /etc/tls/certs/external/tls.crt
          enabled: true
          key_file: /etc/tls/certs/external/tls.key
          name: default
          require_client_auth: false
          truststore_file: /etc/tls/certs/external/ca.crt
      pandaproxy_client:
        broker_tls:
          enabled: true
          require_client_auth: false
          truststore_file: /etc/tls/certs/default/ca.crt
        brokers:
        - address: enterprise-test-pool-a-0.enterprise-test.enterprise.svc.cluster.local.
          port: 9093
        - address: enterprise-test-pool-a-1.enterprise-test.enterprise.svc.cluster.local.
          port: 9093
        - address: enterprise-test-pool-a-2.enterprise-test.enterprise.svc.cluster.local.
          port: 9093
      redpanda:
        admin:
        - address: 0.0.0.0
