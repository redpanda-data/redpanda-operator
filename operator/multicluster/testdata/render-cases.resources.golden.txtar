        - --reserve-memory=205M
        - --smp=1
        admin_api:
          addresses:
          - tls-mtls-test-pool-a-0.tls-mtls-test.tls-mtls.svc.cluster.local.:9644
          - tls-mtls-test-pool-a-1.tls-mtls-test.tls-mtls.svc.cluster.local.:9644
          - tls-mtls-test-pool-a-2.tls-mtls-test.tls-mtls.svc.cluster.local.:9644
