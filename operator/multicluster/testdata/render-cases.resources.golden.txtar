          - custom-resources-explicit-test-pool-a-1.custom-resources-explicit-test.custom-resources-explicit.svc.cluster.local.:9093
          - custom-resources-explicit-test-pool-a-2.custom-resources-explicit-test.custom-resources-explicit.svc.cluster.local.:9093
          tls:
