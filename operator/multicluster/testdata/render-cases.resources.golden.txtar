        - cert_file: /etc/tls/certs/default/tls.crt
          enabled: true
          key_file: /etc/tls/certs/default/tls.key
          name: internal
          require_client_auth: false
          truststore_file: /etc/tls/certs/default/ca.crt
        - cert_file: /etc/tls/certs/external/tls.crt
          enabled: true
          key_file: /etc/tls/certs/external/tls.key
          name: default
          require_client_auth: false
          truststore_file: /etc/tls/certs/external/ca.crt
      pandaproxy_client:
        broker_tls:
          enabled: true
          require_client_auth: false
          truststore_file: /etc/tls/certs/default/ca.crt
        brokers:
        - address: tiered-storage-hostpath-test-pool-a-0.tiered-storage-hostpath-test.tiered-storage-hostpath.svc.cluster.local.
          port: 9093
        - address: tiered-storage-hostpath-test-pool-a-1.tiered-storage-hostpath-test.tiered-storage-hostpath.svc.cluster.local.
          port: 9093
        - address: tiered-storage-hostpath-test-pool-a-2.tiered-storage-hostpath-test.tiered-storage-hostpath.svc.cluster.local.
          port: 9093
      redpanda:
        admin:
        - address: 0.0.0.0
          name: internal
          port: 9644
        - address: 0.0.0.0
          name: default
          port: 9645
        admin_api_tls:
        - cert_file: /etc/tls/certs/default/tls.crt
