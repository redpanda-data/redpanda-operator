    name: sasl-scram512-with-tls-test-sidecar
    namespace: sasl-scram512-with-tls
  roleRef:
    apiGroup: rbac.authorization.k8s.io
    kind: Role
    name: sasl-scram512-with-tls-test-sidecar
  subjects:
