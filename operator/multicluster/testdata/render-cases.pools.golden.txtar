                    fieldPath: metadata.namespace
                  path: namespace
    updateStrategy:
      type: OnDelete
    volumeClaimTemplates:
    - metadata:
        labels:
          app.kubernetes.io/component: redpanda
          app.kubernetes.io/instance: monitoring
          app.kubernetes.io/name: redpanda
        name: datadir
      spec:
        accessModes:
        - ReadWriteOnce
