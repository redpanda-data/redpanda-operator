            secretName: monitoring-pool-a-sts-lifecycle
        - configMap:
            name: monitoring-pool-a
          name: base-config
        - emptyDir: {}
          name: config
        - name: monitoring-pool-a-configurator
          secret:
            defaultMode: 509
            secretName: monitoring-pool-a-configurator
        - name: datadir
          persistentVolumeClaim:
            claimName: datadir
        - name: kube-api-access
          projected:
            defaultMode: 420
            sources:
            - serviceAccountToken:
                expirationSeconds: 3607
                path: token
            - configMap:
                items:
                - key: ca.crt
                  path: ca.crt
                name: kube-root-ca.crt
            - downwardAPI:
                items:
                - fieldRef:
