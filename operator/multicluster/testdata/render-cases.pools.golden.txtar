            name: admin
          - containerPort: 9645
            name: admin-default
          - containerPort: 8082
            name: http
          - containerPort: 8083
            name: http-default
          - containerPort: 9093
            name: kafka
          - containerPort: 9094
            name: kafka-default
          - containerPort: 33145
            name: rpc
          - containerPort: 8081
            name: schemaregistry
          - containerPort: 8084
            name: schema-default
