          name: bootstrap-yaml-envsubst
          resources:
            limits:
              cpu: 100m
              memory: 125Mi
            requests:
              cpu: 100m
              memory: 125Mi
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            runAsNonRoot: true
          volumeMounts:
          - mountPath: /tmp/config/
            name: config
          - mountPath: /tmp/base-config/
            name: base-config
        securityContext:
          fsGroup: 101
          fsGroupChangePolicy: OnRootMismatch
          runAsUser: 101
        serviceAccountName: rack-awareness-test
        terminationGracePeriodSeconds: 90
        topologySpreadConstraints:
        - labelSelector:
            matchLabels:
              app.kubernetes.io/component: redpanda-pool-a-statefulset
              app.kubernetes.io/instance: rack-awareness-test
              app.kubernetes.io/name: redpanda
          maxSkew: 1
          topologyKey: topology.kubernetes.io/zone
          whenUnsatisfiable: ScheduleAnyway
        volumes:
        - name: redpanda-default-cert
          secret:
            defaultMode: 288
            secretName: rack-awareness-test-default-cert
        - name: redpanda-external-cert
          secret:
            defaultMode: 288
            secretName: rack-awareness-test-external-cert
        - name: lifecycle-scripts
          secret:
            defaultMode: 509
            secretName: rack-awareness-test-sts-lifecycle
        - configMap:
            name: rack-awareness-test-pool-a
          name: base-config
        - emptyDir: {}
          name: config
        - name: rack-awareness-test-configurator
          secret:
            defaultMode: 509
            secretName: rack-awareness-test-pool-a-configurator
        - name: datadir
          persistentVolumeClaim:
            claimName: datadir
        - name: kube-api-access
          projected:
            defaultMode: 420
            sources:
            - serviceAccountToken:
                expirationSeconds: 3607
                path: token
            - configMap:
                items:
                - key: ca.crt
                  path: ca.crt
                name: kube-root-ca.crt
            - downwardAPI:
                items:
                - fieldRef:
                    apiVersion: v1
                    fieldPath: metadata.namespace
                  path: namespace
    updateStrategy:
      type: OnDelete
    volumeClaimTemplates:
    - metadata:
        labels:
          app.kubernetes.io/component: redpanda
          app.kubernetes.io/instance: rack-awareness-test
          app.kubernetes.io/name: redpanda
        name: datadir
      spec:
        accessModes:
        - ReadWriteOnce
        resources:
          requests:
            storage: 20Gi
      status: {}
  status:
    availableReplicas: 0
    replicas: 0
