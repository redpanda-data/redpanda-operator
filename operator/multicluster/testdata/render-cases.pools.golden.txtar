          - mountPath: /etc/redpanda
            name: config
          - mountPath: /tmp/base-config
            name: base-config
          - mountPath: /etc/secrets/configurator/scripts/
            name: multi-pool-test-configurator
        - command:
          - /redpanda-operator
          - bootstrap
          - --in-dir
          - /tmp/base-config
          - --out-dir
          - /tmp/config
          image: docker.redpanda.com/redpandadata/redpanda-operator:v99.9.9
          name: bootstrap-yaml-envsubst
          resources:
            limits:
              cpu: 100m
              memory: 125Mi
            requests:
              cpu: 100m
              memory: 125Mi
