        labels:
          app.kubernetes.io/component: redpanda
          app.kubernetes.io/instance: multi-pool
          app.kubernetes.io/name: redpanda
        name: datadir
      spec:
        accessModes:
        - ReadWriteOnce
        resources:
          requests:
            storage: 20Gi
      status: {}
