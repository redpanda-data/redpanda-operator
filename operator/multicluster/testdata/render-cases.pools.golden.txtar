            name: kube-api-access
            readOnly: true
        initContainers:
        - command:
          - /bin/bash
          - -c
          - rpk redpanda tune all
          image: docker.redpanda.com/redpandadata/redpanda:v99.9.9
          name: tuning
          resources: {}
          securityContext:
            capabilities:
              add:
              - SYS_RESOURCE
            privileged: true
            runAsGroup: 0
            runAsNonRoot: false
            runAsUser: 0
          volumeMounts:
          - mountPath: /etc/tls/certs/default
            name: redpanda-default-cert
          - mountPath: /etc/tls/certs/external
            name: redpanda-external-cert
          - mountPath: /etc/redpanda
            name: base-config
        - command:
          - /bin/sh
          - -c
          - chown 101:101 -R /var/lib/redpanda/data
