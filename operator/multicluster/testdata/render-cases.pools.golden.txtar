          app.kubernetes.io/instance: tiered-storage-hostpath
          app.kubernetes.io/name: redpanda
        name: datadir
      spec:
        accessModes:
        - ReadWriteOnce
        resources:
          requests:
            storage: 20Gi
      status: {}
  status:
    availableReplicas: 0
    replicas: 0
