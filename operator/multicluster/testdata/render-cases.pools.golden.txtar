          - --redpanda-cluster-namespace
          - external-nodeport
          - --redpanda-cluster-name
          - external-nodeport-test
          - --selector=app.kubernetes.io/name=redpanda,app.kubernetes.io/instance=external-nodeport-test
          - --run-broker-probe
          - --broker-probe-broker-url
          - $(SERVICE_NAME).external-nodeport-test.external-nodeport.svc.cluster.local.:9644
          command:
          - /redpanda-operator
          env:
          - name: SERVICE_NAME
            valueFrom:
