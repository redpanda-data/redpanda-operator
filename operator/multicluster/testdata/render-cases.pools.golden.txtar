-- custom-cluster-domain --
- apiVersion: apps/v1
  kind: StatefulSet
  metadata:
    labels:
      app.kubernetes.io/component: redpanda-pool-a
      app.kubernetes.io/instance: custom-cluster-domain-test
      app.kubernetes.io/managed-by: redpanda-operator
      app.kubernetes.io/name: redpanda
      cluster.redpanda.com/nodepool-generation: "0"
      cluster.redpanda.com/nodepool-name: pool-a
    name: custom-cluster-domain-test-pool-a
    namespace: custom-cluster-domain
  spec:
    podManagementPolicy: Parallel
    replicas: 3
    selector:
      matchLabels:
        app.kubernetes.io/component: redpanda-pool-a-statefulset
        app.kubernetes.io/instance: custom-cluster-domain-test
        app.kubernetes.io/name: redpanda
    serviceName: custom-cluster-domain-test
    template:
      metadata:
        annotations:
          config.redpanda.com/checksum: a90b21628d89546d234075143f437a7118e87dca2eb009f7ffb653e7b8f09eca
        labels:
          app.kubernetes.io/component: redpanda-pool-a-statefulset
          app.kubernetes.io/instance: custom-cluster-domain-test
          app.kubernetes.io/managed-by: redpanda-operator
          app.kubernetes.io/name: redpanda
          cluster.redpanda.com/broker: "true"
          redpanda.com/poddisruptionbudget: custom-cluster-domain-test
      spec:
        affinity:
          podAntiAffinity:
            requiredDuringSchedulingIgnoredDuringExecution:
            - labelSelector:
