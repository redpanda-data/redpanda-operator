          - --redpanda-cluster-namespace
          - minimal
          - --redpanda-cluster-name
          - minimal-test
          - --selector=app.kubernetes.io/name=redpanda,app.kubernetes.io/instance=minimal-test
          - --run-broker-probe
          - --broker-probe-broker-url
          - $(SERVICE_NAME).minimal-test.minimal.svc.cluster.local.:9644
