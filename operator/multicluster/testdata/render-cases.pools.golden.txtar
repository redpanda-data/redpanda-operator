      app.kubernetes.io/name: redpanda
      cluster.redpanda.com/nodepool-generation: "0"
      cluster.redpanda.com/nodepool-name: pool-hot
      team: data-platform
    name: full-featured-pool-hot
    namespace: full-featured
  spec:
    podManagementPolicy: Parallel
    replicas: 3
