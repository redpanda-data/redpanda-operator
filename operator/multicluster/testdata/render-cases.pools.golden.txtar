                "https://${SERVICE_NAME}.minimal-test.minimal.svc.cluster.local.:9644/v1/status/ready"
            failureThreshold: 3
            initialDelaySeconds: 10
            periodSeconds: 10
          name: redpanda
          ports:
          - containerPort: 9644
            name: admin
          - containerPort: 9645
            name: admin-default
          - containerPort: 8082
            name: http
          - containerPort: 8083
            name: http-default
          - containerPort: 9093
            name: kafka
          - containerPort: 9094
            name: kafka-default
          - containerPort: 33145
            name: rpc
          - containerPort: 8081
            name: schemaregistry
          - containerPort: 8084
