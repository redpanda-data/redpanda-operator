-- compat-test --
pools:
- apiVersion: cluster.redpanda.com/v1alpha2
  kind: NodePool
  metadata:
    name: basic-a
  spec:
    clusterRef:
      group: cluster.redpanda.com/v1alpha2
      kind: StretchCluster
      name: cluster
    replicas: 1
  status: {}
- apiVersion: cluster.redpanda.com/v1alpha2
  kind: NodePool
  metadata:
    name: basic-b
  spec:
    clusterRef:
      group: cluster.redpanda.com/v1alpha2
      kind: StretchCluster
      name: cluster
    replicas: 1
    sidecarImage:
      repository: localhost/test
      tag: dev
  status: {}
spec:
  external:
    enabled: true
    service:
      enabled: true
    type: NodePort
  listeners:
    admin:
      external:
        default:
          advertisedPorts:
          - 31644
          port: 9645
          tls:
            cert: external
      port: 9644
      tls:
        cert: default
        requireClientAuth: false
    http:
      external:
        default:
          advertisedPorts:
          - 30082
          port: 8083
          tls:
            cert: external
      port: 8082
      tls:
        cert: default
        requireClientAuth: false
    kafka:
      external:
        default:
          advertisedPorts:
          - 31092
          port: 9094
          tls:
            cert: external
      port: 9093
      tls:
        cert: default
        requireClientAuth: false
    rpc:
      port: 33145
      tls:
        cert: default
        requireClientAuth: false
    schemaRegistry:
      external:
        default:
          advertisedPorts:
          - 30081
          port: 8084
          tls:
            cert: external
      port: 8081
      tls:
        cert: default
        requireClientAuth: false
  logging:
    logLevel: info
  rbac:
    enabled: true
  resources:
    cpu:
      cores: "1"
    memory:
      container:
        max: 2560Mi
  serviceAccount:
    create: true
  storage:
    persistentVolume:
      enabled: true
      size: 20Gi
  tls:
    certs:
      default:
        caEnabled: true
      external:
        caEnabled: true
    enabled: true
  tuning:
    tune_aio_events: true
