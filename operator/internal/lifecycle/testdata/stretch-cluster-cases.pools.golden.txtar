-- flat-network-test --
- apiVersion: apps/v1
  kind: StatefulSet
  metadata:
    labels:
      app.kubernetes.io/cluster-name: ""
      app.kubernetes.io/component: redpanda-pool-a
      app.kubernetes.io/instance: flat-network-test
      app.kubernetes.io/managed-by: redpanda-operator
      app.kubernetes.io/name: redpanda
      cluster.redpanda.com/namespace: flat-network-test
      cluster.redpanda.com/nodepool-generation: "0"
      cluster.redpanda.com/nodepool-name: pool-a
      cluster.redpanda.com/owner: flat-network-test
    name: flat-network-test-pool-a
    namespace: flat-network-test
  spec:
    podManagementPolicy: Parallel
    replicas: 1
    selector:
      matchLabels:
        app.kubernetes.io/cluster-name: ""
        app.kubernetes.io/component: redpanda-pool-a-statefulset
        app.kubernetes.io/instance: flat-network-test
        app.kubernetes.io/name: redpanda
    serviceName: flat-network-test
    template:
      metadata:
        annotations:
          config.redpanda.com/checksum: a90b21628d89546d234075143f437a7118e87dca2eb009f7ffb653e7b8f09eca
        labels:
          app.kubernetes.io/cluster-name: ""
          app.kubernetes.io/component: redpanda-pool-a-statefulset
          app.kubernetes.io/instance: flat-network-test
