  strategy: {}
  template:
    metadata:
      annotations:
        checksum/config: 44e632405e10e419e4cb3a5f69d2911edabaa8fd561fc25ec1017dc35a99fc96
      labels:
        app.kubernetes.io/instance: redpanda
        app.kubernetes.io/name: console
