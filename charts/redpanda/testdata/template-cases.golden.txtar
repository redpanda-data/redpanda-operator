        name: bootstrap-yaml-envsubst
        resources:
          limits:
            cpu: 100m
            memory: 125Mi
          requests:
            cpu: 100m
            memory: 125Mi
        securityContext:
          allowPrivilegeEscalation: false
          readOnlyRootFilesystem: true
          runAsNonRoot: true
        volumeMounts:
        - mountPath: /tmp/config/
          name: config
        - mountPath: /tmp/base-config/
          name: base-config
      nodeSelector: {}
      restartPolicy: Never
      securityContext:
        fsGroup: 101
        fsGroupChangePolicy: OnRootMismatch
        runAsUser: 101
      serviceAccountName: redpanda
      tolerations: []
      volumes:
      - name: redpanda-default-cert
        secret:
          defaultMode: 288
          secretName: redpanda-default-cert
      - name: redpanda-external-cert
        secret:
          defaultMode: 288
          secretName: redpanda-external-cert
      - name: users
        secret:
          secretName: some-users
      - configMap:
          name: redpanda
        name: base-config
      - emptyDir: {}
        name: config
