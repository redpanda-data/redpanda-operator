          runAsNonRoot: true
        volumeMounts:
        - mountPath: /tmp/config/
          name: config
        - mountPath: /tmp/base-config/
          name: base-config
      nodeSelector: {}
      restartPolicy: Never
      securityContext:
        fsGroup: 101
        fsGroupChangePolicy: OnRootMismatch
        runAsUser: 101
      serviceAccountName: redpanda
      tolerations: []
      volumes:
      - name: users
        secret:
          secretName: redpanda-users
      - configMap:
          name: redpanda
        name: base-config
      - emptyDir: {}
        name: config
