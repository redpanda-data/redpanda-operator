    helm.sh/chart: redpanda-25.3.5
  name: also-not-redpanda-configuration
  namespace: default
spec:
  template:
    metadata:
      annotations: {}
      generateName: redpanda-post-
      labels:
        app.kubernetes.io/component: not-redpanda-post-install
        app.kubernetes.io/instance: redpanda
        app.kubernetes.io/name: not-redpanda-configuration
    spec:
      automountServiceAccountToken: false
      containers:
      - command:
        - /redpanda-operator
        - sync-cluster-config
        - --users-directory
        - /etc/secrets/users
        - --redpanda-yaml
        - /tmp/base-config/redpanda.yaml
        - --bootstrap-yaml
        - /tmp/config/.bootstrap.yaml
        env: null
        image: docker.redpanda.com/redpandadata/redpanda-operator:v25.3.4
        name: post-install
        resources: {}
        securityContext: {}
        volumeMounts:
        - mountPath: /etc/tls/certs/default
          name: redpanda-default-cert
        - mountPath: /etc/tls/certs/external
          name: redpanda-external-cert
        - mountPath: /tmp/config
          name: config
        - mountPath: /tmp/base-config
          name: base-config
      imagePullSecrets: []
      initContainers:
      - command:
        - /redpanda-operator
        - bootstrap
        - --in-dir
        - /tmp/base-config
        - --out-dir
        - /tmp/config
        env: null
        image: docker.redpanda.com/redpandadata/redpanda-operator:v25.3.4
        name: bootstrap-yaml-envsubst
        resources:
          limits:
            cpu: 100m
            memory: 125Mi
          requests:
            cpu: 100m
            memory: 125Mi
        securityContext:
          allowPrivilegeEscalation: false
          readOnlyRootFilesystem: true
          runAsNonRoot: true
        volumeMounts:
        - mountPath: /tmp/config/
          name: config
        - mountPath: /tmp/base-config/
          name: base-config
      nodeSelector: {}
      restartPolicy: Never
      securityContext:
        fsGroup: 101
        fsGroupChangePolicy: OnRootMismatch
        runAsUser: 101
      serviceAccountName: also-not-redpanda
      tolerations: []
      volumes:
      - name: redpanda-default-cert
        secret:
          defaultMode: 288
          secretName: also-not-redpanda-default-cert
      - name: redpanda-external-cert
        secret:
          defaultMode: 288
          secretName: also-not-redpanda-external-cert
      - configMap:
          name: also-not-redpanda
        name: base-config
      - emptyDir: {}
        name: config
