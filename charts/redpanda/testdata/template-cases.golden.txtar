        readinessProbe:
          failureThreshold: 3
          httpGet:
            path: /healthz
            port: 8093
          initialDelaySeconds: 1
          periodSeconds: 10
          successThreshold: 1
          timeoutSeconds: 0
        resources: {}
        volumeMounts:
        - mountPath: /etc/tls/certs/default
          name: redpanda-default-cert
        - mountPath: /etc/tls/certs/external
