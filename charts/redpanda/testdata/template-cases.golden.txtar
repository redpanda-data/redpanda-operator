    rpk redpanda config --config "$CONFIG" set redpanda.advertised_kafka_api[2] "${ADVERTISED_KAFKA_ADDRESSES[$POD_ORDINAL]}"

    ADVERTISED_KAFKA_ADDRESSES=()

    PREFIX_TEMPLATE="ext3-$POD_ORDINAL"
