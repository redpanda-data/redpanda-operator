        - containerPort: 8083
          name: http-default
        - containerPort: 9093
          name: kafka
        - containerPort: 9094
          name: kafka-default
        - containerPort: 33145
          name: rpc
        - containerPort: 8081
          name: schemaregistry
        - containerPort: 8084
          name: schema-default
        resources:
          limits:
            cpu: 1
            memory: 2.5Gi
        startupProbe:
          exec:
