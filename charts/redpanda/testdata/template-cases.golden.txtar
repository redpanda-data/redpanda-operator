        fsGroup: 99
        fsGroupChangePolicy: Always
        runAsUser: 99
      serviceAccountName: redpanda-console
      tolerations: []
      topologySpreadConstraints: []
      volumes:
      - configMap:
          name: redpanda-console
        name: configs
      - name: redpanda-certificates
        projected:
          sources:
          - secret:
              items:
              - key: ca.crt
                path: secrets/redpanda-default-cert/ca.crt
              name: redpanda-default-cert
