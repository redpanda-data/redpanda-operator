        env: null
        image: docker.redpanda.com/redpandadata/redpanda:v25.3.14
        name: tuning
        resources: {}
        securityContext:
          capabilities:
            add:
            - SYS_RESOURCE
          privileged: true
          runAsGroup: 0
          runAsNonRoot: false
          runAsUser: 0
        volumeMounts:
        - mountPath: /etc/tls/certs/default
          name: redpanda-default-cert
        - mountPath: /etc/tls/certs/external
          name: redpanda-external-cert
        - mountPath: /etc/redpanda
          name: base-config
        - mountPath: /var/lib/redpanda/data
          name: datadir
      - command:
