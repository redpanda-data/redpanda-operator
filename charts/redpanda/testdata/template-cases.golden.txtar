                post-start $(date): /" | tee /proc/1/fd/1; true'
          preStop:
            exec:
              command:
              - bash
              - -c
              - 'timeout -v 45 bash -x /var/lifecycle/preStop.sh 2>&1 | sed "s/^/lifecycle-hook
                pre-stop $(date): /" | tee /proc/1/fd/1; true'
