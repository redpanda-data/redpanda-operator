        name: base-config
      - emptyDir: {}
        name: config
      - name: redpanda-configurator
        secret:
          defaultMode: 509
          secretName: redpanda-configurator
      - name: datadir
        persistentVolumeClaim:
          claimName: datadir
      - name: kube-api-access
        projected:
          defaultMode: 420
          sources:
