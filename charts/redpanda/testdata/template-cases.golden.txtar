      imagePullSecrets: []
      initContainers:
      - command:
        - /redpanda-operator
        - bootstrap
        - --in-dir
        - /tmp/base-config
        - --out-dir
        - /tmp/config
        env: null
        image: docker.redpanda.com/redpandadata/redpanda-operator:v25.3.4
        name: bootstrap-yaml-envsubst
        resources:
          limits:
