            cpu: 100m
            memory: 125Mi
        securityContext:
          allowPrivilegeEscalation: false
          readOnlyRootFilesystem: true
          runAsNonRoot: true
        volumeMounts:
        - mountPath: /tmp/config/
          name: config
        - mountPath: /tmp/base-config/
          name: base-config
      nodeSelector: {}
      priorityClassName: ""
      securityContext:
        fsGroup: 101
        fsGroupChangePolicy: OnRootMismatch
        runAsUser: 101
      serviceAccountName: redpanda
      terminationGracePeriodSeconds: 90
