        - --selector=helm.sh/chart=redpanda-25.3.5,app.kubernetes.io/name=redpanda,app.kubernetes.io/instance=redpanda
        - --run-broker-probe
        - --broker-probe-broker-url
        - $(SERVICE_NAME).redpanda.default.svc.cluster.local.:9644
        command:
        - /redpanda-operator
