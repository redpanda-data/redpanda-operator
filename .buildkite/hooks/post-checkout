# important: assumes that each agent runs a single job at a time

# ignore errors
set +e

if [[ $BUILDKITE_AGENT_META_DATA_QUEUE == "devprod-t4gmicro" ]]; then
  echo "Skipping on 'devprod-t4gmicro' agents"
  exit 0
fi

echo "Cleaning up unused docker containers"
for id in $(docker ps --quiet); do
  echo "Killing $id"
  docker kill $id
done

docker container prune --force
docker volume prune --force
docker network prune --force
